openai_base_url=https://coding.dashscope.aliyuncs.com/v1
openai_model=qwen3.5-plus
llm_provider=openai


knowledge_dir=docs/knowledge
rag_top_k=3
rag_chunk_size=300
rag_chunk_overlap=50
